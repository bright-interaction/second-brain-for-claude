{
  "_comment": "Generated by second-brain-for-claude setup. See docs/hooks-explained.md for what each hook does.",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(DYLD_LIBRARY_PATH=*)",
      "Edit(**)",
      "Read(**)",
      "Write(**)",
      "Glob(**)",
      "Grep(**)",
      "WebFetch(*)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(*> /dev/sd*)",
      "Bash(mkfs*)",
      "Bash(dd if=*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat <<'HOOKEOF'\n{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"ENFORCED RULES:\\n\\n1. GRAPHIFY FIRST: Query the knowledge graph (DYLD_LIBRARY_PATH=/opt/homebrew/opt/expat/lib ~/.local/bin/graphify query) before reading source files or grepping. Fast index, low token cost.\\n\\n2. {{WIKI_NAME_UPPER}} SECOND: Read {{WIKI_PATH}}/index.md and the relevant entity page for deeper context when graphify is not enough.\\n\\n3. WORK ORDER: Graphify -> {{WIKI_NAME}} -> Source -> Execute -> Commit -> Push -> Edit {{WIKI_NAME}} -> Commit {{WIKI_NAME}} -> Rebuild graphify. No exceptions.\\n\\n4. NEVER claim done until you have updated {{WIKI_NAME}} and rebuilt graphify.\"}}\nHOOKEOF"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"REMINDER: Query graphify first (fast index), then read {{WIKI_NAME}} entity pages at {{WIKI_PATH}}/entities/ for deeper context. Do not grep raw files until both are checked.\"}}'",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"AGENT CONTEXT: Include in subagent prompts: 1) Query graphify first (DYLD_LIBRARY_PATH=/opt/homebrew/opt/expat/lib ~/.local/bin/graphify query). 2) Read {{WIKI_NAME}} entities at {{WIKI_PATH}}/entities/ for project context. 3) Do NOT let agents explore from scratch.\"}}'",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"POST-PUSH: Update {{WIKI_NAME}} now (3 steps, no exceptions):\\n1) Edit {{WIKI_PATH}}/entities/<project>.md + append to log.md\\n2) Commit {{WIKI_NAME}}: cd {{WIKI_PATH}} && git add -A && git commit -m sync:\\n3) Rebuild graphify: DYLD_LIBRARY_PATH=/opt/homebrew/opt/expat/lib ~/.local/bin/graphify query rebuild\\nDo NOT ask. Do NOT skip step 2.\"}}'",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
